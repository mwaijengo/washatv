# Copy to `.env` for local dev:  cp .env.example .env
# `npm run dev` loads `.env` automatically (via dotenv). Railway uses its dashboard variables instead.
#
# --- Align with Flutter apps (compile-time --dart-define) ---
# Production uses the API deployed on Railway directly (default URL below).
# Override WASHA_API_BASE_URL only for local backend dev (e.g. http://127.0.0.1:8080).
# User app [lib/services/public_api_service.dart]:
#   WASHA_API_BASE_URL   = same origin you use below for the public API (no trailing slash)
#     default in code: https://washatv-production.up.railway.app
# Admin app [lib/admin/admin_dashboard_app.dart]:
#   WASHA_API_BASE_URL   = must match this API base URL
#   WASHA_ADMIN_API_KEY  = must match ADMIN_API_KEY here (same string) when you set it
# -----------------------------------------------------------------------------

# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/washa

# Required by schema (min 16 chars). Change in production.
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# CORS: * = reflect any Origin (good for Flutter web on random localhost ports).
# Production: comma-separated exact origins, e.g. https://app.example.com,https://admin.example.com
# Localhost on any port is also allowed by code when this is not *.
CORS_ORIGIN=*

# Optional: admin login (JWT). If both missing, login route returns 503 unless ADMIN_API_KEY is set.
ADMIN_EMAIL=admin@washa.local
# bcrypt hash — generate: node scripts/hash-password.mjs "your-secret"
ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash

# Optional: same value you pass as Flutter --dart-define=WASHA_ADMIN_API_KEY for slides/channels/etc.
ADMIN_API_KEY=

# Optional Postgres pool cap (defaults in code if unset)
# PG_POOL_MAX=20
