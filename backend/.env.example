# Railway / local Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/washa

# Admin login (POST /api/v1/admin/auth/login)
ADMIN_EMAIL=admin@washa.local
# bcrypt hash of your password — generate: node -e "require('bcrypt').hash('your-secret',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash

# JWT for admin sessions (min 32 chars in production)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Optional: lock admin routes to this key instead of JWT (header X-Admin-Key)
# ADMIN_API_KEY=

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# CORS — comma-separated origins (Flutter web / admin). Use * only in dev.
CORS_ORIGIN=*
