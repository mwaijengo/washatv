# Railway / local Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/washa

# Admin login is optional at boot, but required for JWT-based admin sign-in.
# If omitted, public API still works and admin routes return 503 unless ADMIN_API_KEY is set.
ADMIN_EMAIL=admin@washa.local
# bcrypt hash of your password — generate: node scripts/hash-password.mjs "your-secret"
ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash

# Strong JWT secret for admin sessions (recommended in production).
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Optional: use this header instead of JWT for server-to-server admin actions.
# ADMIN_API_KEY=

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# CORS — comma-separated origins (Flutter web / admin). Use * only in dev.
CORS_ORIGIN=*
